# ==========================================================================
# Estabilis Workload – Azure Variables
# ==========================================================================
# Copy this file to terraform.tfvars and fill in the required values.
#
#   cp terraform.tfvars.example terraform.tfvars
#
# Then run:
#   terraform init
#   terraform plan
#   terraform apply
#
# Terraform loads terraform.tfvars automatically (no -var-file needed).
# ==========================================================================

# --- Required ---

subscription_id = ""
tenant_id       = ""

# --- Environment ---

environment = "prod"
# name_prefix = "estabilis"
# location    = "eastus2"

# --- Optional features ---
# velero_enabled      = false
# diagnostics_enabled = false
# keyvault_enabled    = false

# --- ACR ---
# acr_enabled = true
# acr_sku     = "Premium"

# --- Network ---
# Options: default, cilium, cilium-acns, byo-cni
# network_dataplane = "cilium"
#
# IMPORTANT: byo-cni DESTROYS and RECREATES the cluster. Apply in two steps:
#   1. terraform apply -target=azurerm_kubernetes_cluster.workload -target=helm_release.cilium
#   2. terraform apply
# Destroy in two steps (avoids Helm timeout when cluster is already gone):
#   1. terraform state rm helm_release.cilium
#   2. terraform destroy
# NOTE: Step 1 of apply may fail with "NotFound" if Azure hasn't propagated the
# cluster deletion. Wait ~1 minute and retry the same command.
# network_dataplane       = "byo-cni"
# byo_cni_i_understand_this_destroys_the_cluster = true
# cilium_version          = "1.19.2"

# --- Platform access ---
# Platform NAT gateway IP — required for ArgoCD to reach this workload's API server.
# Get from platform: terraform output -raw nat_gateway_public_ip
# authorized_ip_ranges = ["<platform-nat-gateway-ip>/32"]

# --- Docker Hub cache (requires Docker Hub account) ---
# acr_cache_dockerhub_enabled = true
# acr_dockerhub_username      = ""
# acr_dockerhub_token         = ""

# --- Hub registration ---
# Automates workload registration in the platform hub.
# Requires the platform's workload operator to be deployed on the hub cluster first.
#
# Step 1 — Get values from the platform:
#   hub_api_server_url  → terraform output -raw hub_api_server_url  (estabilis-platform)
#   hub_registrar_token → published automatically to the hub Key Vault by the
#                           workload operator (Workload Identity); read from KV
#                           when hub_key_vault_name is set. No CLI required.
#
# apiServerAccess mode is auto-derived: enable_private_cluster=true → "private"
# (no allowlisting). For a PUBLIC workload cluster, set mode "allowlist" and
# provide the hub egress IP:
#   hub_registration_api_server_access_mode = "allowlist"
#   hub_egress_ip = "<hub NAT GW IP>"   # or populate the hub-egress-ip KV secret
# When allowlisting, remove the same IP from authorized_ip_ranges above to
# avoid duplication.
#
# hub_registration_enabled = true
# hub_api_server_url        = ""
# hub_registrar_token       = ""  # only needed when NOT reading from hub Key Vault
# # hub_registration_api_server_access_mode = ""   # "" = auto (private|allowlist)
# # hub_egress_ip                           = ""   # allowlist mode only
